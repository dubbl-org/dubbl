{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "echo 'cron service - no build needed'"
  },
  "deploy": {
    "startCommand": "node scripts/cron-all.mjs",
    "cronSchedule": "*/5 * * * *",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
