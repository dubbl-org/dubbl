{
  "name": "@dubbl/ocr",
  "version": "0.1.0",
  "description": "Deterministic receipt and invoice OCR for bookkeeping. Tesseract-powered, no AI / cloud dependency.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./parsers": {
      "types": "./src/parsers/index.ts",
      "import": "./src/parsers/index.ts"
    },
    "./preprocess": {
      "types": "./src/preprocess.ts",
      "import": "./src/preprocess.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "ocr",
    "receipt",
    "invoice",
    "tesseract",
    "expense",
    "bookkeeping"
  ],
  "license": "MIT",
  "peerDependencies": {
    "tesseract.js": ">=5"
  },
  "publishConfig": {
    "access": "public"
  }
}
