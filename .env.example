# =============================================================================
# Dubbl — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# If using Docker Compose, these defaults work out of the box.

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# For Docker Compose: postgresql://dubbl:dubbl@localhost:5432/dubbl
DATABASE_URL="postgresql://dubbl:dubbl@localhost:5432/dubbl"

# -----------------------------------------------------------------------------
# Authentication — NextAuth (Required)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="local-dev-secret-change-me-in-production"

# Public app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------------------------------------
# Google — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple — https://developer.apple.com/sign-in-with-apple
# Option A (recommended): provide your .p8 key as base64 for runtime JWT generation
#   To encode: base64 -w0 AuthKey_XXXXXXXXXX.p8
AUTH_APPLE_ID=""
AUTH_APPLE_TEAM_ID=""
AUTH_APPLE_KEY_ID=""
AUTH_APPLE_KEY_BASE64=""
# Option B: provide a pre-generated JWT secret (expires after 6 months)
# AUTH_APPLE_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (Optional — needed for billing features)
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Seat plan price IDs from your Stripe product catalog
STRIPE_PRO_PRICE_ID=""
STRIPE_PRO_ANNUAL_PRICE_ID=""
# Storage add-on price IDs (monthly)
STRIPE_STORAGE_STARTER_PRICE_ID=""
STRIPE_STORAGE_GROWTH_PRICE_ID=""
STRIPE_STORAGE_SCALE_PRICE_ID=""

# Storage add-on price IDs (annual)
STRIPE_STORAGE_STARTER_ANNUAL_PRICE_ID=""
STRIPE_STORAGE_SCALE_ANNUAL_PRICE_ID=""
STRIPE_STORAGE_GROWTH_ANNUAL_PRICE_ID=""

# Stripe Connect (Optional — needed for user Stripe account integration)
STRIPE_CONNECT_CLIENT_ID=""
STRIPE_CONNECT_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Email — Resend (Optional — needed for notification digests & platform emails)
# -----------------------------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=""

# Cron secret for protecting scheduled endpoints (e.g. notification digests)
CRON_SECRET=""

# -----------------------------------------------------------------------------
# S3 / Object Storage (Optional — needed for file uploads)
# -----------------------------------------------------------------------------
# For Docker Compose (MinIO): use these defaults
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="dubbl"

# -----------------------------------------------------------------------------
# Self-Hosting (Optional)
# -----------------------------------------------------------------------------
# REGISTRATION_MODE="open"          # open, invite_only, disabled
# ALLOWED_EMAIL_DOMAINS=""          # comma-separated: acme.com,example.com
