# =============================================================================
# Dubbl — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# If using Docker Compose, these defaults work out of the box.

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# For Docker Compose: postgresql://dubbl:dubbl@localhost:5432/dubbl
DATABASE_URL="postgresql://dubbl:dubbl@localhost:5432/dubbl"

# -----------------------------------------------------------------------------
# Authentication — NextAuth (Required)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="local-dev-secret-change-me-in-production"

# Public app URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------------------------------------
# Google — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple — https://developer.apple.com
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (Optional — needed for billing features)
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Price IDs from your Stripe product catalog
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""

# -----------------------------------------------------------------------------
# S3 / Object Storage (Optional — needed for file uploads)
# -----------------------------------------------------------------------------
# For Docker Compose (MinIO): use these defaults
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="dubbl"
