# =============================================================================
# Dubbl — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/dubbl"

# -----------------------------------------------------------------------------
# Authentication — NextAuth (Required)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public app URL (used for Stripe redirects, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------------------------------------
# Google — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple — https://developer.apple.com
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# -----------------------------------------------------------------------------
# Stripe (Optional — needed for billing features)
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Price IDs from your Stripe product catalog
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""

# -----------------------------------------------------------------------------
# S3 / Object Storage (Optional — needed for file uploads)
# -----------------------------------------------------------------------------
# Works with AWS S3 or any S3-compatible service (MinIO, DigitalOcean Spaces)
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="dubbl"
